# https://ghostty.org/docs/config/reference
background          = 000
theme               = Rose Pine
font-family         = Iosevka Nerd Font Mono
window-height       = 9999
window-width        = 9999
split-divider-color = #F0f0f0

keybind = ctrl+left=esc:b
keybind = ctrl+right=esc:f
keybind = ctrl+tab=ignore
keybind = ctrl+equal=increase_font_size:4
keybind = ctrl+-=decrease_font_size:4

cursor-style = block
cursor-style-blink = true

background-blur = true
background-opacity = 0.988

# Font:
font-size = 12.5
font-thicken = true


# General
gtk-titlebar = false
shell-integration-features = no-cursor,no-sudo,no-title
confirm-close-surface=false
keybind = ctrl+enter=unbind
